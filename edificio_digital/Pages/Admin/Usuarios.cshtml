@page
@model edificio_digital.Pages.Admin.UsuariosModel
@{
    ViewData["Title"] = "Usuarios";
}

<h1 class="h3 mb-3">Usuarios</h1>
<p class="text-muted small">Listado de usuarios y sus roles activos.</p>

<table class="table table-sm align-middle">
    <thead><tr>
        <th>Nombre</th><th>Correo</th><th>Roles</th><th>Estado</th>
    </tr></thead>
    <tbody>
        @foreach (var u in Model.Usuarios)
        {
            <tr>
                <td>@u.NombreCompleto</td>
                <td>@u.Email</td>
                <td><span class="badge bg-secondary">@string.Join(", ", u.Roles)</span></td>
                <td>@(u.Activo ? "Activo" : "Inactivo")</td>
            </tr>
        }
    </tbody>
</table>
