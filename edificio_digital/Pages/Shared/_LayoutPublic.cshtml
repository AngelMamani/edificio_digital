@using edificio_digital.Models.Common
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Edificio digital</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-public">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-page="@AppConstants.Pages.Home">Edificio digital</a>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="@AppConstants.Pages.Home">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Privacy">Privacidad</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" asp-page="@AppConstants.Pages.Login">Iniciar sesión</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        <div class="alert alert-secondary py-2 small mb-3">Layout público — accesible sin autenticación</div>
        @RenderBody()
    </main>

    <footer class="border-top text-muted py-3">
        <div class="container small">&copy; 2026 Edificio digital · Layout público</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
