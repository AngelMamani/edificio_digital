@page
@model edificio_digital.Pages.LoginModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-shell">
    <div class="login-backdrop" aria-hidden="true"></div>

    <div class="login-content">
        <header class="login-brand">
            <span class="login-brand-mark" aria-hidden="true">ED</span>
            <div>
                <span class="login-brand-title">Edificio digital</span>
                <span class="login-brand-tagline">Acceso institucional</span>
            </div>
        </header>

        <div class="login-card">
            <div class="login-card-accent" aria-hidden="true"></div>
            <h1 class="login-title">Iniciar sesión</h1>
            <p class="login-subtitle">Usa tu correo y contraseña asignados. Los datos viajan solo al servidor de esta aplicación.</p>

            <form method="post" class="login-form mt-4">
                <div class="form-field">
                    <label asp-for="LoginInput.Email" class="login-label"></label>
                    <div class="login-input-wrap">
                        <svg class="login-input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                        </svg>
                        <input asp-for="LoginInput.Email" type="email" autocomplete="username" class="form-control login-input input-with-icon" placeholder="nombre@ejemplo.edu.pe" />
                    </div>
                    <span asp-validation-for="LoginInput.Email" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="form-field">
                    <label asp-for="LoginInput.Contrasena" class="login-label"></label>
                    <div class="login-input-wrap">
                        <svg class="login-input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                        <input asp-for="LoginInput.Contrasena" type="password" autocomplete="current-password" class="form-control login-input input-with-icon" placeholder="Tu contraseña" />
                    </div>
                    <span asp-validation-for="LoginInput.Contrasena" class="text-danger small d-block mt-1"></span>
                </div>

                <button type="submit" class="btn login-button w-100">Ingresar</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="login-alert @(Model.IsSuccess ? "alert-success" : "alert-danger") mt-3" role="alert">
                    @Model.Message
                </div>
            }

            @if (Model.IsSuccess && Model.LoginResult is not null)
            {
                <section class="login-result" aria-label="Sesión iniciada">
                    <div class="login-result-header">Datos de la sesión (demostración)</div>
                    <dl>
                        <div class="login-result-row">
                            <dt>Nombre</dt>
                            <dd>@Model.LoginResult.NombreCompleto</dd>
                        </div>
                        <div class="login-result-row">
                            <dt>Correo</dt>
                            <dd>@Model.LoginResult.Email</dd>
                        </div>
                        <div class="login-result-row">
                            <dt>Rol</dt>
                            <dd>@Model.LoginResult.Rol</dd>
                        </div>
                        <div class="login-result-row">
                            <dt>Token demo</dt>
                            <dd class="login-result-token">@Model.LoginResult.Token</dd>
                        </div>
                    </dl>
                </section>
            }
        </div>

        <p class="login-foot">
            <a asp-page="/Index">← Volver al inicio</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
