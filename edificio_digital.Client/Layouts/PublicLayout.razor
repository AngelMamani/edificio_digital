@inherits LayoutComponentBase

<div class="layout-public d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom">
            <div class="container">
                <a class="navbar-brand fw-semibold" href="/">Edificio digital</a>
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Inicio</NavLink></li>
                    <AuthorizeView>
                        <NotAuthorized>
                            <li class="nav-item ms-2"><a class="btn btn-primary btn-sm" href="/login">Iniciar sesión</a></li>
                        </NotAuthorized>
                        <Authorized>
                            <li class="nav-item ms-2"><a class="btn btn-outline-primary btn-sm" href="@LandingFor(context)">Ir a mi panel</a></li>
                        </Authorized>
                    </AuthorizeView>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container py-4 flex-grow-1">
        @Body
    </main>

    <footer class="border-top text-secondary py-3 mt-auto">
        <div class="container small">© 2026 Edificio digital · Layout público</div>
    </footer>
</div>

@code {
    private static string LandingFor(AuthenticationState ctx) =>
        ctx.User.IsInRole(AppConstants.Roles.Admin) ? "/admin" :
        ctx.User.IsInRole(AppConstants.Roles.Solicitante) ? "/solicitante" :
        "/";
}
