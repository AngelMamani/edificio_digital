<div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
    <div>
        @if (!string.IsNullOrEmpty(Eyebrow))
        {
            <span class="ed-eyebrow d-inline-flex mb-2"><i class="dot"></i> @Eyebrow</span>
        }
        <h1 class="h3 mb-0 fw-medium" style="letter-spacing:-0.025em;">@Title</h1>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <p class="text-secondary small mb-0 mt-1">@Subtitle</p>
        }
    </div>
    @if (Actions is not null)
    {
        <div class="d-flex gap-2">@Actions</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
