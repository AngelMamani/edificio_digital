@page
@model edificio_digital.Pages.Solicitante.IndexModel
@{
    ViewData["Title"] = "Mis solicitudes";
}

<h1 class="h3 mb-3">Hola @User.Identity?.Name</h1>
<p class="text-muted">Estás dentro del layout exclusivo del rol <code>solicitante</code>.</p>

<div class="card mt-3 border-0 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Mis reservas</h5>
        <p class="text-muted small">Aún no tienes reservas registradas.</p>
        <a class="btn btn-primary btn-sm" asp-page="/Solicitante/NuevaReserva">+ Nueva reserva</a>
    </div>
</div>
