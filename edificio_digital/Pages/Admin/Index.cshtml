@page
@model edificio_digital.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Panel administrador";
}

<h1 class="h3 mb-3">Panel administrador</h1>
<p class="text-muted">Bienvenido <strong>@User.Identity?.Name</strong>. Estás dentro del layout exclusivo del rol <code>admin</code>.</p>

<div class="row g-3 mt-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <h6 class="text-uppercase small text-muted">Usuarios</h6>
            <p class="display-6 mb-1">3</p>
            <a asp-page="/Admin/Usuarios" class="small">Ir a usuarios →</a>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <h6 class="text-uppercase small text-muted">Ambientes</h6>
            <p class="display-6 mb-1">—</p>
            <span class="small text-muted">Pendiente de configurar</span>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <h6 class="text-uppercase small text-muted">Reservas</h6>
            <p class="display-6 mb-1">—</p>
            <span class="small text-muted">Pendiente de configurar</span>
        </div></div>
    </div>
</div>
